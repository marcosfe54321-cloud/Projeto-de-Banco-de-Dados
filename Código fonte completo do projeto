from sqlalchemy.orm import DeclarativeBase, Mapped, mapped_column, relationship, sessionmaker

# Configuração da Conexão
DATABASE_URL = "postgresql://postgres:senha@localhost:5432/postgres"
engine = create_engine(DATABASE_URL)
SessionLocal = sessionmaker(bind=engine, autoflush=False, autocommit=False)

class Base(DeclarativeBase):
    pass

# Tabela Associativa N:N (Jogo <-> Coleção)
# Essencial para que um jogo pertença a múltiplas listas personalizadas.
jogo_colecao = Table(
    "jogo_colecao",
    Base.metadata,
    Column("id_jogo", ForeignKey("jogo.id_jogo"), primary_key=True),
    Column("id_colecao", ForeignKey("colecao.id_colecao"), primary_key=True),
)

class Usuario(Base):
    __tablename__ = "usuario"
    id_usuario: Mapped[int] = mapped_column(primary_key=True)
    nome: Mapped[str] = mapped_column(String(50), unique=True)
    email: Mapped[str] = mapped_column(String(100), unique=True)
    senha: Mapped[str] = mapped_column(String(255))
    jogos: Mapped[List["Jogo"]] = relationship(back_populates="dono")

class Jogo(Base):
    __tablename__ = "jogo"
    id_jogo: Mapped[int] = mapped_column(primary_key=True)
    id_usuario: Mapped[int] = mapped_column(ForeignKey("usuario.id_usuario"))
    id_genero: Mapped[int] = mapped_column(ForeignKey("genero.id_genero"))
    titulo: Mapped[str] = mapped_column(String(100))
    status: Mapped[str] = mapped_column(String(20), default="não iniciado")
    horas_jogadas: Mapped[float] = mapped_column(Numeric(10,2), default=0.00)
    avaliacao: Mapped[Optional[int]] = mapped_column(Integer)

    dono: Mapped["Usuario"] = relationship(back_populates="jogos")
    colecoes: Mapped[List["Colecao"]] = relationship(secondary=jogo_colecao, back_populates="jogos")

class Genero(Base):
    __tablename__ = "genero"
    id_genero: Mapped[int] = mapped_column(primary_key=True)
    nome: Mapped[str] = mapped_column(String(50), unique=True)

class Colecao(Base):
    __tablename__ = "colecao"
    id_colecao: Mapped[int] = mapped_column(primary_key=True)
    id_usuario: Mapped[int] = mapped_column(ForeignKey("usuario.id_usuario"))
    nome_colecao: Mapped[str] = mapped_column(String(50))
    jogos: Mapped[List["Jogo"]] = relationship(secondary=jogo_colecao, back_populates="colecoes")

