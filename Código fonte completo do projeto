-- III. OTIMIZAÇÃO E AUTOMAÇÃO
-- Índices para transformar Seq Scan em Index Scan em grandes volumes.
CREATE INDEX idx_jogo_titulo ON jogo(titulo);
CREATE INDEX idx_jogo_id_genero ON jogo(id_genero);

-- View Materializada para dashboards de alta performance.
CREATE MATERIALIZED VIEW mv_resumo_estatistico AS
SELECT g.nome AS genero, COUNT(j.id_jogo) AS total_jogos, ROUND(AVG(j.avaliacao), 2) AS media_notas
FROM genero g
LEFT JOIN jogo j ON g.id_genero = g.id_genero
GROUP BY g.nome;

-- Trigger para validar tempo mínimo de 1h antes de finalizar um jogo.
CREATE OR REPLACE FUNCTION fn_valida_progresso() RETURNS TRIGGER AS $$
BEGIN
    IF (NEW.status = 'finalizado' AND NEW.horas_jogadas < 1.0) THEN
        RAISE EXCEPTION 'Erro: Um jogo exige ao menos 1h registrada para ser finalizado.';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_valida_conclusao
BEFORE INSERT OR UPDATE ON jogo
FOR EACH ROW EXECUTE FUNCTION fn_valida_progresso();

    
