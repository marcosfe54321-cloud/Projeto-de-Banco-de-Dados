-- III. MECANISMOS AVANÇADOS
CREATE OR REPLACE VIEW v_catalogo_detalhado AS
SELECT j.titulo AS jogo, g.nome AS categoria, u.nome AS dono, j.status
FROM jogo j INNER JOIN genero g ON j.id_genero = g.id_genero
INNER JOIN usuario u ON u.id_usuario = j.id_usuario;

CREATE MATERIALIZED VIEW mv_resumo_estatistico AS
SELECT g.nome AS genero, COUNT(j.id_jogo) AS total, ROUND(AVG(j.avaliacao), 2) AS media
FROM genero g LEFT JOIN jogo j ON g.id_genero = g.id_genero GROUP BY g.nome;

CREATE OR REPLACE FUNCTION fn_valida_progresso() RETURNS TRIGGER AS $$
BEGIN
    IF (NEW.status = 'finalizado' AND NEW.horas_jogadas < 1.0) THEN
        RAISE EXCEPTION 'Erro: Regra de 1h não atendida.';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_valida_conclusao BEFORE INSERT OR UPDATE ON jogo
FOR EACH ROW EXECUTE FUNCTION fn_valida_progresso();

-- IV. ÍNDICES DE OTIMIZAÇÃO
