-- =============================================================================
-- 1. LIMPEZA PREVENTIVA
-- =============================================================================
-- Garante que o script possa ser executado do início ao fim sem erros de duplicidade.
DROP VIEW IF EXISTS v_catalogo_detalhado;
DROP MATERIALIZED VIEW IF EXISTS mv_estatisticas_genero;
DROP TABLE IF EXISTS jogo_colecao CASCADE;
DROP TABLE IF EXISTS colecao CASCADE;
DROP TABLE IF EXISTS jogo CASCADE;
DROP TABLE IF EXISTS plataforma CASCADE;
DROP TABLE IF EXISTS genero CASCADE;
DROP TABLE IF EXISTS usuario CASCADE;

-- =============================================================================
-- 2. DDL - ESTRUTURA E INTEGRIDADE (ETAPAS 1, 2 e 4)
-- =============================================================================

-- Tabela: usuario (identidade e preferências)
CREATE TABLE usuario (
    id_usuario SERIAL PRIMARY KEY,
    -- UNIQUE: Impede duplicidade de nomes e e-mails
    nome VARCHAR(50) NOT NULL CONSTRAINT uq_usuario_nome UNIQUE,
    email VARCHAR(100) NOT NULL CONSTRAINT uq_usuario_email UNIQUE,
    senha VARCHAR(255) NOT NULL,
    plataforma_principal VARCHAR(20),
    meta_anual_jogos INTEGER DEFAULT 0,
    -- DEFAULT: Registra automaticamente o carimbo de data do sistema
    data_cadastro TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Tabela: genero (categorias de jogos)
CREATE TABLE genero (
    id_genero SERIAL PRIMARY KEY,
    nome VARCHAR(50) NOT NULL UNIQUE
);

-- Tabela: plataforma (sistemas/hardwares)
CREATE TABLE plataforma (
    id_plataforma SERIAL PRIMARY KEY,
    nome VARCHAR(50) NOT NULL UNIQUE
);

-- Tabela: jogo (entidade principal do catálogo)
CREATE TABLE jogo (
    id_jogo SERIAL PRIMARY KEY,
    id_usuario INTEGER NOT NULL,
    id_genero INTEGER NOT NULL,
    id_plataforma INTEGER NOT NULL,
    titulo VARCHAR(100) NOT NULL,
    -- DEFAULT: Todo jogo novo inicia com status pendente
    status VARCHAR(20) DEFAULT 'não iniciado',
    -- DEFAULT: Inicializa o contador de horas zerado
    horas_jogadas NUMERIC(10,2) DEFAULT 0.00,
    avaliacao INTEGER,
    data_inicio DATE,
    data_termino DATE,
    
    -- POLÍTICAS REFERENCIAIS:
    -- ON DELETE CASCADE: Remove jogos se o usuário dono for excluído
    CONSTRAINT fk_jogo_usuario FOREIGN KEY (id_usuario) 
        REFERENCES usuario(id_usuario) ON DELETE CASCADE ON UPDATE CASCADE,
    
    -- ON DELETE RESTRICT: Protege classificações mestras vinculadas
    CONSTRAINT fk_jogo_genero FOREIGN KEY (id_genero) 
        REFERENCES genero(id_genero) ON DELETE RESTRICT ON UPDATE CASCADE,
    
    CONSTRAINT fk_jogo_plataforma FOREIGN KEY (id_plataforma) 
        REFERENCES plataforma(id_plataforma) ON DELETE RESTRICT ON UPDATE CASCADE,
    
    -- CONSTRAINTS CHECK: Validações automáticas de negócio
    CONSTRAINT ck_status CHECK (status IN ('não iniciado', 'jogando', 'finalizado')),
    CONSTRAINT ck_avaliacao CHECK (avaliacao >= 0 AND avaliacao <= 10),
    CONSTRAINT ck_horas_positivas CHECK (horas_jogadas >= 0)
);

-- Tabela: colecao (listas personalizadas do utilizador)
CREATE TABLE colecao (
    id_colecao SERIAL PRIMARY KEY,
    id_usuario INTEGER NOT NULL,
    nome_colecao VARCHAR(50) NOT NULL,
    CONSTRAINT fk_colecao_usuario FOREIGN KEY (id_usuario) 
        REFERENCES usuario(id_usuario) ON DELETE CASCADE ON UPDATE CASCADE
);

-- Tabela Associativa: jogo_colecao (Relacionamento N:N)
CREATE TABLE jogo_colecao (
    id_jogo INTEGER NOT NULL,
    id_colecao INTEGER NOT NULL,
    -- Chave Primária Composta: Garante unicidade do jogo na lista
    PRIMARY KEY (id_jogo, id_colecao),
    CONSTRAINT fk_rel_jogo FOREIGN KEY (id_jogo) 
        REFERENCES jogo(id_jogo) ON DELETE CASCADE ON UPDATE CASCADE,
    CONSTRAINT fk_rel_colecao FOREIGN KEY (id_colecao) 
        REFERENCES colecao(id_colecao) ON DELETE CASCADE ON UPDATE CASCADE
);

