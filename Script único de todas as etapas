-- 4. RECURSOS AVANÇADOS (ETAPA 5)
-- =============================================================================

-- VIEW: Listagem técnica consolidada do catálogo para a aplicação
CREATE OR REPLACE VIEW v_catalogo_detalhado AS
SELECT 
    j.titulo AS jogo, g.nome AS categoria, p.nome AS plataforma, u.nome AS dono, j.status
FROM jogo j 
INNER JOIN genero g ON j.id_genero = g.id_genero
INNER JOIN plataforma p ON j.id_plataforma = p.id_plataforma
INNER JOIN usuario u ON u.id_usuario = j.id_usuario;

-- VIEW MATERIALIZADA: Relatório analítico com agregação de performance
CREATE MATERIALIZED VIEW mv_estatisticas_genero AS
SELECT 
    g.nome AS genero, 
    COUNT(j.id_jogo) AS total_jogos, 
    ROUND(AVG(j.avaliacao), 2) AS media_notas,
    SUM(j.horas_jogadas) AS total_horas_gastas
FROM genero g 
LEFT JOIN jogo j ON g.id_genero = j.id_genero 
GROUP BY g.nome;

-- TRIGGER BEFORE: Impede marcar jogo como finalizado com menos de 1h registrada
CREATE OR REPLACE FUNCTION fn_valida_progresso() RETURNS TRIGGER AS $$
BEGIN
    IF (NEW.status = 'finalizado' AND NEW.horas_jogadas < 1.0) THEN
        RAISE EXCEPTION 'Erro de Negócio: Um jogo exige ao menos 1h registrada para ser finalizado.';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_valida_conclusao
BEFORE INSERT OR UPDATE ON jogo
FOR EACH ROW EXECUTE FUNCTION fn_valida_progresso();

-- TRIGGER AFTER: Cria coleção padrão para cada novo usuário cadastrado
CREATE OR REPLACE FUNCTION fn_cria_colecao_padrao() RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO colecao (id_usuario, nome_colecao) VALUES (NEW.id_usuario, 'meus favoritos');
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_auto_colecao AFTER INSERT ON usuario
FOR EACH ROW EXECUTE FUNCTION fn_cria_colecao_padrao();

-- PROCEDURE: Centraliza a rotina de reiniciar o progresso de um jogo via CALL
CREATE OR REPLACE PROCEDURE sp_reiniciar_jogo(p_id_jogo INT) AS $$
BEGIN
    UPDATE jogo SET status = 'jogando', horas_jogadas = 0.00 WHERE id_jogo = p_id_jogo;
    COMMIT;
END;
$$ LANGUAGE plpgsql;

